{
	"extends": "../tsconfig.base.json",
	"compilerOptions": {
		"declaration": true,
		"composite": true,
		"declarationMap": true,
		"outDir": "dist",
		"rootDir": "src",
		"module": "ESNext",
		"target": "ES2020",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"isolatedModules": false,
		"skipLibCheck": true,
		"baseUrl": "./src",
		"paths": {
			"@workspace/shared": ["./"],
			"@workspace/shared/*": ["./*"]
		},
		"noUnusedLocals": true,
		"noUnusedParameters": true
	},
	"include": ["src"],
	"exclude": ["dist", "node_modules"]
}
